// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  profile             Profile?
  templateUsage       TemplateUsage[]
  createdPrompts      Prompt[]
  templateGenerations TemplateGeneration[]
  clients             Client[]
}

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  phoneNumber String?
  address     String?
  city        String?
  country     String?
  postalCode  String?

  // Company details
  companyName     String?
  companyWebsite  String?
  companyIndustry String?
  jobTitle        String?
  companySize     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TemplateUsage {
  id     String  @id @default(cuid())
  userId String? // Optional - can track anonymous users too

  // Core Template Data
  templateType String // Professional, Promotional, etc.
  templateId   String // Template index (0-8)

  // URL Data
  urlCount Int // Number of URLs processed (1 or multiple)

  // User Context (from profile if available)
  userIndustry    String? // User's company industry
  userCompanySize String? // Company size segment
  userCountry     String? // Geographic segment

  // Success/Failure
  wasSuccessful Boolean // Did the generation succeed

  // Timestamp
  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([templateType])
  @@index([templateId])
  @@index([createdAt])
  @@index([userIndustry])
  @@index([userCompanySize])
  @@index([wasSuccessful])
}

// Prompt Management Models
model Prompt {
  id          String  @id @default(cuid())
  name        String // "Professional Email Template"
  description String? // Brief description of template
  color       String  @default("#6366f1") // Color for template selection boxes

  // Core prompt content
  systemPrompt String @db.Text
  userPrompt   String @db.Text

  // AI Configuration
  designEngine DesignEngine @default(CLAUDE) // CLAUDE or GPT4O

  // Template Type
  templateType TemplateType @default(SINGLE_PRODUCT) // SINGLE_PRODUCT or MULTI_PRODUCT

  // Versioning & Management
  version   String       @default("1.0.0")
  status    PromptStatus @default(DRAFT) // DRAFT, ACTIVE, ARCHIVED
  isDefault Boolean      @default(false)

  // Metadata
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastTestedAt DateTime?
  testResults  Json? // Store test results and metrics

  // Usage Analytics
  usageCount  Int    @default(0)
  successRate Float? // Success rate from tests

  // Relations
  creator             User                 @relation(fields: [createdBy], references: [id])
  templateGenerations TemplateGeneration[]

  @@index([status])
  @@index([createdBy])
  @@index([isDefault])
}

model TemplateGeneration {
  id       String  @id @default(cuid())
  promptId String
  userId   String?

  // Input data
  inputUrl    String
  productInfo Json // Scraped product info

  // Output data  
  generatedHtml String  @db.Text
  subject       String?

  // Performance metrics
  generationTime Int // milliseconds
  wasSuccessful  Boolean
  errorMessage   String?

  createdAt DateTime @default(now())

  // Relations
  prompt Prompt @relation(fields: [promptId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([promptId])
  @@index([userId])
  @@index([createdAt])
}

model Country {
  code      String   @id
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientConfigs   ClientCountryConfig[]
  campaignTargets CampaignCountry[]
}

model Client {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  industry    String?
  website     String?
  notes       String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  integrations   ClientIntegration[]
  countryConfigs ClientCountryConfig[]
  campaigns      Campaign[]
  productSources ProductSource[]
  products       Product[]
  productSyncRuns ProductSyncRun[]
  campaignPlans  CampaignPlan[]

  @@index([userId])
  @@index([isArchived])
}

model ClientIntegration {
  id                   String              @id @default(cuid())
  clientId             String
  provider             IntegrationProvider
  status               IntegrationStatus   @default(PENDING)
  encryptedCredentials String?
  metadata             Json?
  lastSyncedAt         DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, provider])
}

model ClientCountryConfig {
  id              String    @id @default(cuid())
  clientId        String
  countryCode     String
  isActive        Boolean   @default(false)
  mailingListId   String?
  mailingListName String?
  senderEmail     String? // Sender email for this country (must match SqualoMail)
  senderName      String? // Sender name for this country
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryCode], references: [code], onDelete: Restrict)

  @@unique([clientId, countryCode])
  @@index([countryCode])
}

model Campaign {
  id          String         @id @default(cuid())
  clientId    String
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  externalId  String?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  client         Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  countryTargets CampaignCountry[]

  subject    String? @db.Text
  preheader  String? @db.Text
  senderName String?
  utmMedium  String?

  productUrl      String? @db.Text
  productNickname String?
  productInfoJson String? @db.LongText
  countryResultsJson String? @db.LongText
  templateId      String?
}

model CampaignCountry {
  id            String   @id @default(cuid())
  campaignId    String
  countryCode   String
  mailingListId   String?
  mailingListName String?
  externalId      String? // SqualoMail newsletter ID (set AFTER push)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Prepared newsletter data (stored at creation, consumed by cron)
  preparedHtml      String? @db.LongText
  preparedSubject   String? @db.Text
  preparedPreheader String? @db.Text
  preparedFromEmail String?
  preparedFromName  String?
  preparedName      String?
  isPushed          Boolean @default(false)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  country  Country  @relation(fields: [countryCode], references: [code], onDelete: Restrict)

  @@unique([campaignId, countryCode, mailingListId])
  @@index([countryCode])
}

model ProductSource {
  id           String   @id @default(cuid())
  clientId     String
  name         String?
  url          String   @db.Text
  countryCode  String?
  crawlDepth   Int      @default(1)
  isEnabled    Boolean  @default(true)
  config       Json?
  lastSyncedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  syncRuns ProductSyncRun[]
  listings ProductListing[]

  @@index([clientId])
  @@index([countryCode])
  @@index([isEnabled])
}

model Product {
  id              String        @id @default(cuid())
  clientId        String
  externalKey     String?
  title           String
  normalizedTitle String
  groupKey        String?
  description     String?       @db.Text
  canonicalUrl    String?       @db.Text
  bestImageUrl    String?       @db.Text
  status          ProductStatus @default(ACTIVE)
  metadata        Json?
  firstSeenAt     DateTime      @default(now())
  lastSeenAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  listings  ProductListing[]
  images    ProductImage[]
  planItems CampaignPlanItem[]

  @@unique([clientId, externalKey])
  @@index([clientId])
  @@index([status])
  @@index([normalizedTitle])
  @@index([clientId, groupKey])
}

model ProductListing {
  id           String              @id @default(cuid())
  clientId     String
  productId    String
  sourceId     String?
  countryCode  String?
  url          String              @db.Text
  urlHash      String
  slug         String?
  title        String?
  priceRaw     String?
  regularPrice String?
  salePrice    String?
  currency     String?
  availability ProductAvailability @default(UNKNOWN)
  metadata     Json?
  scrapedAt    DateTime            @default(now())
  lastSeenAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  source  ProductSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([clientId, urlHash])
  @@index([clientId])
  @@index([productId])
  @@index([sourceId])
  @@index([countryCode])
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  url        String   @db.Text
  urlHash    String
  rank       Int      @default(0)
  isSelected Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, urlHash])
  @@index([productId])
}

model ProductSyncRun {
  id              String            @id @default(cuid())
  clientId        String
  sourceId        String?
  status          ProductSyncStatus @default(RUNNING)
  startedAt       DateTime          @default(now())
  finishedAt      DateTime?
  discoveredCount Int               @default(0)
  createdCount    Int               @default(0)
  updatedCount    Int               @default(0)
  missingCount    Int               @default(0)
  failedCount     Int               @default(0)
  errorMessage    String?           @db.Text
  log             Json?

  client Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source ProductSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  events ProductSyncEvent[]

  @@index([clientId])
  @@index([sourceId])
  @@index([status])
  @@index([startedAt])
}

model ProductSyncEvent {
  id        String               @id @default(cuid())
  runId     String
  type      ProductSyncEventType
  productId String?
  listingId String?
  url       String?              @db.Text
  message   String?              @db.Text
  createdAt DateTime             @default(now())

  run ProductSyncRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([type])
}

model CampaignPlan {
  id          String             @id @default(cuid())
  clientId    String
  name        String
  month       Int
  year        Int
  mode        CampaignPlanMode   @default(MANUAL)
  status      CampaignPlanStatus @default(DRAFT)
  strategy    Json?
  approvedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  client Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items  CampaignPlanItem[]

  @@index([clientId])
  @@index([year, month])
  @@index([status])
}

model CampaignPlanItem {
  id               String                 @id @default(cuid())
  planId           String
  productId        String?
  campaignId       String?
  type             CampaignPlanItemType   @default(TEST)
  status           CampaignPlanItemStatus @default(PLANNED)
  position         Int                    @default(0)
  sendDate         DateTime?
  countryCodes     Json?
  templateId       String?
  groupKey         String?
  subject          String?                @db.Text
  preheader        String?                @db.Text
  mailingListOverrides Json?
  selectedImageUrl String?                @db.Text
  priceOverride    String?
  notes            String?                @db.Text
  errorMessage     String?                @db.Text
  productSnapshot  Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  plan    CampaignPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  product Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([productId])
  @@index([campaignId])
}

enum DesignEngine {
  CLAUDE
  GPT4O
}

enum PromptStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum IntegrationProvider {
  SQUALOMAIL
  KLAVIYO
  MAILCHIMP
}

enum IntegrationStatus {
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
}

enum CampaignStatus {
  DRAFT
  READY
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum TemplateType {
  SINGLE_PRODUCT
  MULTI_PRODUCT
}

enum ProductStatus {
  ACTIVE
  POSSIBLY_UNAVAILABLE
  ARCHIVED
}

enum ProductAvailability {
  IN_STOCK
  OUT_OF_STOCK
  UNKNOWN
}

enum ProductSyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum ProductSyncEventType {
  CREATED
  UPDATED
  MISSING
  FAILED
}

enum CampaignPlanMode {
  MANUAL
  ASSISTED
}

enum CampaignPlanStatus {
  DRAFT
  APPROVED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum CampaignPlanItemType {
  WINNER
  TEST
  MANUAL
}

enum CampaignPlanItemStatus {
  PLANNED
  QUEUED
  GENERATING
  SCHEDULED
  FAILED
}
